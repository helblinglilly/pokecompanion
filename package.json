{
  "name": "pokecompanion",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "npm run build:app",
    "build:assets": "node scripts/socialpreviews/socialGenerator.js",
    "build:app": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "schema": "npx openapi-typescript https://api.pokecompanion.com/docs/swagger.json -o ./src/@types/api.d.ts",
    "schema:local": "npx openapi-typescript http://localhost:3000/docs/swagger.json -o ./src/@types/api.d.ts"
  },
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.1",
		"@cloudflare/workers-types": "^4.20260619.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/adapter-vercel": "^6.3.4",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
		"baseline-browser-mapping": "^2.10.38",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "esm": "^3.2.25",
    "jest-dom": "^4.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "node-fetch": "^3.3.2",
    "openapi-typescript": "^7.13.0",
		"prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "save-svg-as-png": "^1.4.17",
    "sharp": "^0.35.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "marked": "^18.0.5"
  }
}
